# Contact form email delivery (via Resend — https://resend.com).
# The site works without these set (submissions are accepted and logged),
# but you won't receive emails until they're configured.

# 1. Sign up at resend.com (free tier: ~3,000 emails/month).
# 2. Create an API key and paste it here.
RESEND_API_KEY=

# The address that receives quote requests (your inbox).
CONTACT_TO_EMAIL=you@example.com

# The "from" address. Must be on a domain you've verified in Resend,
# OR use onboarding@resend.dev for quick testing.
CONTACT_FROM_EMAIL=onboarding@resend.dev
